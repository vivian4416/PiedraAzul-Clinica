{
  "info": {
    "_postman_id": "2f4e8b6e-9c87-4c3f-8f4d-0f4d7d5b1d21",
    "name": "PiedraAzul API",
    "description": "Coleccion para probar la API con Keycloak y CRUD de usuarios desde Postman. El request de token usa password grant y funciona mejor con un cliente dedicado de Postman que permita Direct Access Grants en Keycloak.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Keycloak",
      "item": [
        {
          "name": "Obtener token (password grant)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "{{kcGrantType}}"
                },
                {
                  "key": "client_id",
                  "value": "{{postmanClientId}}"
                },
                {
                  "key": "client_secret",
                  "value": "{{postmanClientSecret}}",
                  "disabled": false
                },
                {
                  "key": "username",
                  "value": "{{kcUsername}}"
                },
                {
                  "key": "password",
                  "value": "{{kcPassword}}"
                },
                {
                  "key": "scope",
                  "value": "openid"
                }
              ]
            },
            "url": {
              "raw": "{{keycloakBaseUrl}}/realms/{{realm}}/protocol/openid-connect/token",
              "host": [
                "{{keycloakBaseUrl}}"
              ],
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token"
              ]
            },
            "description": "Obtiene access_token y refresh_token para usar en el resto de la coleccion. Recomendado: crear un client dedicado para Postman con Direct Access Grants habilitado."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Respuesta valida', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "if (data.access_token) {",
                  "  pm.environment.set('accessToken', data.access_token);",
                  "}",
                  "if (data.refresh_token) {",
                  "  pm.environment.set('refreshToken', data.refresh_token);",
                  "}",
                  "if (data.expires_in) {",
                  "  pm.environment.set('tokenExpiresIn', String(data.expires_in));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "auth": {
